{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "choose_action_v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["action_type", "payload"],
  "properties": {
    "action_type": {
      "type": "string",
      "enum": ["MOVE", "EXPLORE", "USE", "TAKE", "REST", "ATTACK", "GET", "TOSS"]
    },
    "payload": {
      "type": "object"
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "reason_code": {
      "type": "string",
      "enum": ["SURVIVAL_FIRST", "RESOURCE_RECOVER", "ATTACK_OPPORTUNITY", "RISK_AVOID", "DEFAULT_SAFE"]
    }
  },
  "allOf": [
    {
      "if": { "properties": { "action_type": { "const": "MOVE" } }, "required": ["action_type"] },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "additionalProperties": false,
            "required": ["move_dir"],
            "properties": {
              "move_dir": { "type": "string", "enum": ["UP", "DOWN", "LEFT", "RIGHT"] }
            }
          }
        }
      }
    },
    {
      "if": { "properties": { "action_type": { "const": "EXPLORE" } }, "required": ["action_type"] },
      "then": {
        "properties": { "payload": { "type": "object", "additionalProperties": false } }
      }
    },
    {
      "if": { "properties": { "action_type": { "const": "REST" } }, "required": ["action_type"] },
      "then": {
        "properties": { "payload": { "type": "object", "additionalProperties": false } }
      }
    },
    {
      "if": { "properties": { "action_type": { "const": "TOSS" } }, "required": ["action_type"] },
      "then": {
        "properties": { "payload": { "type": "object", "additionalProperties": false } }
      }
    },
    {
      "if": { "properties": { "action_type": { "const": "USE" } }, "required": ["action_type"] },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "additionalProperties": false,
            "required": ["items"],
            "properties": {
              "items": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["item_type", "qty"],
                  "properties": {
                    "item_type": {
                      "type": "string",
                      "enum": ["bread", "bottled_water", "compressed_biscuit", "canned_food", "barrel_water", "clean_water"]
                    },
                    "qty": { "type": "integer", "minimum": 1 }
                  }
                }
              }
            }
          }
        }
      }
    },
    {
      "if": { "properties": { "action_type": { "enum": ["TAKE", "GET"] } }, "required": ["action_type"] },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "additionalProperties": false,
            "required": ["items"],
            "properties": {
              "items": {
                "type": "array",
                "minItems": 1,
                "maxItems": 3,
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": ["item_type", "qty"],
                  "properties": {
                    "item_type": {
                      "type": "string",
                      "enum": ["bread", "bottled_water", "compressed_biscuit", "canned_food", "barrel_water", "clean_water"]
                    },
                    "qty": { "type": "integer", "minimum": 1, "maximum": 3 }
                  }
                }
              }
            }
          }
        }
      }
    },
    {
      "if": { "properties": { "action_type": { "const": "ATTACK" } }, "required": ["action_type"] },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "additionalProperties": false,
            "required": ["target_player_id"],
            "properties": {
              "target_player_id": { "type": "string", "minLength": 1 }
            }
          }
        }
      }
    }
  ],
  "$comment": "TAKE/GET total_qty<=3 is enforced by server business validation in addition to schema checks."
}
