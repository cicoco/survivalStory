{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "action_rejected_v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "error_code", "reason", "allowed_actions"],
  "properties": {
    "schema": {
      "type": "string",
      "const": "action_rejected_v1"
    },
    "error_code": {
      "type": "string"
    },
    "reason": {
      "type": "string"
    },
    "allowed_actions": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["MOVE", "EXPLORE", "USE", "TAKE", "REST", "ATTACK", "GET", "TOSS"]
      }
    }
  }
}

