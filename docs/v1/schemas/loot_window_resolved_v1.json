      "minLength": 1
    },
    "winner_player_id": {
      "type": "string",
      "minLength": 1
    },
    "loser_player_id": {
      "type": "string",
      "minLength": 1
    },
    "choice": {
      "type": "string",
      "enum": ["GET", "TOSS"]
    },
    "obtained": {
      "type": "object",
      "additionalProperties": {
        "type": "integer",
        "minimum": 0
      }
